{
    "name": "2lenet/entity-file-bundle",
    "type": "symfony-bundle",
    "description": "This package allows you to attach files to entities",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Lle\\EntityFileBundle\\": "src/"
        }
    },
    "authors": [
        {
            "name": "2LE"
        }
    ],
    "require": {
        "php": "^8.4",
        "league/flysystem-bundle": "^3.0",
        "doctrine/orm": "^2.12 || ^3.0",
        "doctrine/doctrine-bundle": "^2.6 || ^3.0",
        "symfony/webpack-encore-bundle": "^2.0",
        "gedmo/doctrine-extensions": "^3.7",
        "symfony/form": "^7.0 || ^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "squizlabs/php_codesniffer": "^3.6",
        "slevomat/coding-standard": "^7.1"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
